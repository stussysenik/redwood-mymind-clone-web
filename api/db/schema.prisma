// MyMind Clone - Prisma Schema
// Connects to existing Supabase PostgreSQL instance
// Uses @map directives to bridge camelCase models to snake_case DB columns

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = "native"
  previewFeatures = ["postgresqlExtensions"]
}

// ─── Cards ──────────────────────────────────────────────────────────────────
// Core entity: every saved item becomes a Card
model Card {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String    @map("user_id")
  type                   String    // 'article'|'image'|'note'|'product'|'book'|'video'|'audio'|'social'|'movie'|'website'
  title                  String?
  content                String?
  url                    String?
  imageUrl               String?   @map("image_url")
  embedding              Unsupported("vector(1536)")?
  metadata               Json      @default("{}")
  tags                   String[]  @default([])
  titleConfidence        Float?    @map("title_confidence")
  descriptionConfidence  Float?    @map("description_confidence")
  titleEditedAt          DateTime? @map("title_edited_at") @db.Timestamptz
  descriptionEditedAt    DateTime? @map("description_edited_at") @db.Timestamptz
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz
  archivedAt             DateTime? @map("archived_at") @db.Timestamptz

  enrichmentReviewItems  EnrichmentReviewItem[]

  @@index([userId], map: "idx_cards_user")
  @@index([type], map: "idx_cards_type")
  @@index([tags], type: Gin, map: "idx_cards_tags")
  @@index([metadata], type: Gin, map: "idx_cards_metadata")
  @@index([createdAt(sort: Desc)], map: "idx_cards_created")
  @@index([deletedAt], map: "idx_cards_deleted_at")
  @@index([archivedAt], map: "idx_cards_archived_at")
  @@index([titleConfidence], map: "idx_cards_title_confidence")
  @@map("cards")
}

// ─── Spaces ─────────────────────────────────────────────────────────────────
// Smart collections — filter cards by query/tag matching
model Space {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  name      String
  query     String?
  isSmart   Boolean  @default(false) @map("is_smart")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId], map: "idx_spaces_user_id")
  @@map("spaces")
}

// ─── User Preferences ───────────────────────────────────────────────────────
// Synced user preferences — one row per user, upserted on first save.
// Default values in code mean the table can be empty for existing users.
model UserPreferences {
  userId         String   @id @map("user_id")
  graphRenderer  String   @default("canvas") @map("graph_renderer")
  graphDimension String   @default("2d") @map("graph_dimension")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("user_preferences")
}

// ─── API Tokens ─────────────────────────────────────────────────────────────
// Personal API tokens used by the iOS "BYOA Capture" Shortcut (and future
// mobile-capture clients) to authenticate against /functions/capture.
// The plaintext secret is shown to the user exactly once at creation time;
// only the sha256 hash is stored at rest.
model ApiToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id")
  name       String
  prefix     String    @unique
  tokenHash  String    @map("token_hash")
  scopes     String[]  @default(["cards:write"])
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([userId], map: "idx_api_tokens_user")
  @@index([prefix, revokedAt], map: "idx_api_tokens_lookup")
  @@map("api_tokens")
}

// ─── Graph Clusters ─────────────────────────────────────────────────────────
// User-defined named subgraphs — persistent multi-selections in the 3D graph
model GraphCluster {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  spaceId   String?  @map("space_id")
  name      String   @db.VarChar(60)
  note      String?  @db.VarChar(280)
  nodeIds   String[] @map("node_ids")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId, createdAt], map: "idx_graph_clusters_user_created")
  @@index([userId, spaceId], map: "idx_graph_clusters_user_space")
  @@map("graph_clusters")
}

// ─── Graph Annotations ──────────────────────────────────────────────────────
// Text notes anchored to nodes or clusters, rendered as billboards in 3D space
model GraphAnnotation {
  id         String  @id @default(cuid())
  userId     String  @map("user_id")
  anchorType String  @map("anchor_type") // 'node' | 'cluster'
  anchorId   String  @map("anchor_id")
  text       String  @db.VarChar(280)
  offsetX    Float?  @map("offset_x")
  offsetY    Float?  @map("offset_y")
  offsetZ    Float?  @map("offset_z")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId, createdAt], map: "idx_graph_annotations_user_created")
  @@index([userId, anchorType, anchorId], map: "idx_graph_annotations_user_anchor")
  @@map("graph_annotations")
}

// ─── Enrichment Review Items ────────────────────────────────────────────────
// Queue of title/description proposals from the DSPy pipeline whose critic
// confidence landed in the middle band [REVIEW_THRESHOLD, AUTO_APPLY_THRESHOLD).
// Append-only log — resolution flips resolvedAt/resolution in place.
model EnrichmentReviewItem {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cardId        String    @map("card_id") @db.Uuid
  userId        String    @map("user_id")
  kind          String    // 'title' | 'description'
  proposedValue String    @map("proposed_value")
  currentValue  String?   @map("current_value")
  confidence    Float
  critique      String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt    DateTime? @map("resolved_at") @db.Timestamptz
  resolution    String?   // 'accept' | 'reject' | 'edit' | 'skip'
  editedValue   String?   @map("edited_value")

  card          Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, resolvedAt, createdAt], map: "idx_enrichment_review_pending")
  @@index([cardId], map: "idx_enrichment_review_card")
  @@map("enrichment_review_items")
}

// ─── Enrichment Batch Stats ─────────────────────────────────────────────────
// One row per worker batch — SQL-queryable history of the pipeline's work.
model EnrichmentBatchStats {
  batchId          String    @id @map("batch_id") @db.Uuid
  startedAt        DateTime  @map("started_at") @db.Timestamptz
  finishedAt       DateTime? @map("finished_at") @db.Timestamptz
  cardsProcessed   Int       @default(0) @map("cards_processed")
  autoApplied      Int       @default(0) @map("auto_applied")
  queuedForReview  Int       @default(0) @map("queued_for_review")
  dropped          Int       @default(0) @map("dropped")
  errors           Int       @default(0) @map("errors")

  @@index([startedAt(sort: Desc)], map: "idx_enrichment_batch_stats_started")
  @@map("enrichment_batch_stats")
}
